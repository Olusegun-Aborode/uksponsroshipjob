{
  "name": "sponsorship-job-board",
  "version": "1.0.0",
  "description": "Live UK Skilled Worker sponsorship job board: scans legitimate job feeds, cross-references the gov.uk Register of Licensed Sponsors, scores sponsorship confidence, and tracks applications.",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "npm --prefix web install && npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "test": "node --test",
    "scan": "node src/scan.js",
    "research:scan": "node src/research/scan.js",
    "backup": "node src/backup.js",
    "remind": "node src/reminders.js",
    "register:update": "node scripts/init-register.js",
    "ats:detect": "node scripts/ats-detect.js",
    "init": "node scripts/init-register.js && node src/scan.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "better-sqlite3": "^11.8.1",
    "csv-parse": "^5.6.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "rss-parser": "^3.13.0"
  }
}
