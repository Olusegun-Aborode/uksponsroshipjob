# ---- Copy this file to .env and fill in what you have. Nothing here is required to boot;
# ---- the board runs with whatever sources are configured. Add keys to widen coverage.

# Server
PORT=3000

# Adzuna (recommended backbone — free developer tier). https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed (optional — free API key). https://www.reed.co.uk/developers
REED_API_KEY=

# What to search for. Comma-separated. Tuned to your profile by default.
SEARCH_KEYWORDS=data analyst,data engineer,data scientist,analytics engineer,business intelligence,product manager,product owner,technical product manager,project manager,programme manager,delivery manager,scrum master,crm manager,lifecycle marketing,marketing analytics,business analyst
# Where. Comma-separated. "uk" means nationwide on Adzuna.
SEARCH_LOCATIONS=uk

# Company ATS boards to pull directly (no scraping — these are public JSON feeds).
# Format: provider:slug  (providers: greenhouse, lever, ashby). Comma-separated.
# Find the slug in a company's careers URL, e.g. boards.greenhouse.io/monzo -> greenhouse:monzo
# Tip: `npm run ats:detect "Company Name"` finds the working board for you.
ATS_BOARDS=greenhouse:monzo,greenhouse:gocardless,greenhouse:cleo,ashby:freetrade,ashby:deliveroo,ashby:trainline,lever:moonpig,ashby:tractable,ashby:multiverse,ashby:improbable,ashby:thought-machine,ashby:paddle,ashby:cohere,ashby:synthesia,ashby:photoroom

# How many Adzuna pages (50 jobs each) to pull per keyword. Higher = wider recall.
ADZUNA_MAX_PAGES=5

# Skilled Worker salary gate. General threshold in £/yr; per-occupation going rates live in
# data/soc-going-rates.json. VERIFY both against current gov.uk figures — they change.
# SALARY_PROFILE=new_entrant (default) uses the reduced floor + 70% going rate for Graduate-visa
# switchers / under-26s; set "experienced" for full thresholds.
SALARY_PROFILE=new_entrant
SALARY_THRESHOLD_GENERAL=41700
SALARY_NEW_ENTRANT=33400

# Alerts for new high-tier roles (all optional; skipped if blank).
ALERT_TIERS=A,B-,B
ALERT_MIN_CONFIDENCE=55
# Telegram: create a bot via @BotFather, get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Or any incoming webhook (Slack / Discord / Zapier) — receives {"text": "..."}.
ALERT_WEBHOOK_URL=

# AI CV tailoring + course suggestions (Anthropic Claude). https://console.anthropic.com/
# A few cents per generated CV. Leave blank to disable the AI features.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# Hard cap on AI spend per calendar month (USD). 0 or blank = no cap.
AI_MONTHLY_BUDGET_USD=15

# Password gate (HTTP Basic, any username). REQUIRED before deploying publicly so nobody can
# burn your Claude credits or read your CV. Leave blank for local use.
APP_PASSWORD=

# Reminders + backups
REMINDER_DEADLINE_DAYS=4
REMINDER_FOLLOWUP_DAYS=10
BACKUP_KEEP=14

# Off-box backups to Cloudflare R2 / S3 (optional). If set, each daily snapshot is also uploaded so
# a disk failure can't lose your tracking. For R2: endpoint https://<account-id>.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_REGION=auto
# BACKUP_S3_PREFIX=backups/

# --- Research & Funding section (funded PhDs, postdocs, fellowships) ---
# Adzuna research queries (comma-separated). Blank = sensible defaults across PhD/postdoc/fellowship.
RESEARCH_KEYWORDS=
# Optional paid scraper for deeper funded-PhD coverage (e.g. an Apify run-sync-get-dataset-items URL
# returning a JSON array of items). Dormant unless set. Token sent as a Bearer header.
RESEARCH_SCRAPER_URL=
RESEARCH_SCRAPER_TOKEN=

# gov.uk Register of Licensed Sponsors. Leave AUTO and the app finds the current CSV itself.
# Or set a local path if you downloaded it manually.
REGISTER_CSV=AUTO
